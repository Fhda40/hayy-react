rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — only read/write own doc
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Merchants — public read; auth required for create (must include uid);
    //             update allowed for any auth user (admin + merchant self-update)
    match /merchants/{id} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll(['uid'])
                    && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // Businesses — public read; write requires auth (admin adds businesses)
    match /businesses/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Coupons — auth required to read (admin/merchant verification + own coupons)
    //           create: user_id must match auth uid (prevents creating for others)
    //           update: own user OR status-only update (merchant verification)
    match /coupons/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.user_id;
      allow update: if request.auth != null && (
                      request.auth.uid == resource.data.user_id
                      || request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['status', 'used_at', 'merchant_phone'])
                    );
    }

    // Ratings — public read; authenticated users can create
    match /ratings/{id} {
      allow read: if true;
      allow create: if request.auth != null;
    }

    // Complaints — auth required for all (admin reads all; users create own)
    match /complaints/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    // FCM tokens — strict: each user can only access their own token
    match /fcm_tokens/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
