rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — only read/write own doc
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Merchants — public read active merchants; write requires auth
    match /merchants/{id} {
      allow read: if resource.data.active != false;
      allow write: if request.auth != null;
    }

    // Businesses — public read active; write requires auth
    match /businesses/{id} {
      allow read: if resource.data.active != false;
      allow write: if request.auth != null;
    }

    // Coupons — authenticated users can create/read their own
    match /coupons/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Ratings — anyone authenticated can read; create once per coupon
    match /ratings/{id} {
      allow read: if true;
      allow create: if request.auth != null;
    }

    // Complaints — authenticated users can create
    match /complaints/{id} {
      allow read, write: if request.auth != null;
    }

    // FCM tokens — user can write their own
    match /fcm_tokens/{userId} {
      allow read, write: if request.auth != null;
    }
  }
}
